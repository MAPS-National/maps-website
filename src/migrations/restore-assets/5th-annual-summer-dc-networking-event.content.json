      {
        "children": [
          {
            "detail": 0,
            "format": 1,
            "mode": "normal",
            "style": "",
            "text": "This is a professional networking event for the MAPS membership and Associate Membership. Please do not register or share the event details with any non-members apart from spouses. Colleagues and friends are welcome to register with MAPS directly via ",
            "type": "text",
            "version": 1
          },
