            {
              "detail": 0,
              "format": 0,
              "mode": "normal",
              "style": "",
              "text": "MAPS Academy Training Series",
              "type": "text",
              "version": 1
            }
          ],
          "direction": null,
          "format": "",
          "indent": 0,
          "type": "heading",
          "version": 1,
          "tag": "h2"
        },
        {
          "children": [
            {
