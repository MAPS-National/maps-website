# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links, and SEO. No trailing slash.
# In production set this to the real public origin — next-sitemap/robots and all
# OG/canonical URLs resolve from it (otherwise builds fall back to localhost).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# ---------------------------------------------------------------------------
# Media storage (optional).
#   Unset      -> Payload uses local disk (public/media). Zero infra.
#   All 5 set  -> @payloadcms/storage-s3 activates. One code path for every
#                 backend; MinIO -> R2 -> AWS S3 is a credentials-only change.
#
# Local MinIO parity (matches docker-compose.yml — `docker compose up -d`):
#S3_BUCKET=payload-media
#S3_ENDPOINT=http://localhost:9000
#S3_REGION=us-east-1
#S3_ACCESS_KEY_ID=minioadmin
#S3_SECRET_ACCESS_KEY=minioadmin
#
# Cloudflare R2 (prod, recommended — zero egress, S3-compatible):
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = R2 API token pair
#
# AWS S3 (drop-in alternative):
#   S3_ENDPOINT=https://s3.<region>.amazonaws.com   (or omit for AWS default)
#   S3_REGION=<your-region>                          e.g. us-east-1
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = IAM access key pair
# ---------------------------------------------------------------------------
