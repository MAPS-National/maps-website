# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links, and SEO. No trailing slash.
# In production set this to the real public origin — next-sitemap/robots and all
# OG/canonical URLs resolve from it (otherwise builds fall back to localhost).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# ---------------------------------------------------------------------------
# Media storage (optional).
#   Unset      -> Payload uses local disk (public/media). Zero infra.
#   All 5 set  -> @payloadcms/storage-s3 activates. One code path for every
#                 backend; MinIO -> R2 -> AWS S3 is a credentials-only change.
#
# Local MinIO parity (matches docker-compose.yml — `docker compose up -d`):
#S3_BUCKET=payload-media
#S3_ENDPOINT=http://localhost:9000
#S3_REGION=us-east-1
#S3_ACCESS_KEY_ID=minioadmin
#S3_SECRET_ACCESS_KEY=minioadmin
#
# Cloudflare R2 (prod, recommended — zero egress, S3-compatible):
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = R2 API token pair
#
# AWS S3 (drop-in alternative):
#   S3_ENDPOINT=https://s3.<region>.amazonaws.com   (or omit for AWS default)
#   S3_REGION=<your-region>                          e.g. us-east-1
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = IAM access key pair
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Transactional email (optional) — powers contact-form / form-builder notifications.
#   Unset            -> Payload logs emails to the console. Submissions still
#                       persist to the form-submissions collection (admin panel);
#                       they just aren't emailed. Zero infra.
#   RESEND_API_KEY set -> @payloadcms/email-resend activates and delivers each
#                       form's notification emails.
#
# Setup: create a Resend account, add + verify a sending domain (publish the
# SPF/DKIM DNS records Resend gives you). MAPS already uses Google Workspace, so
# verify a SUBDOMAIN (mail.mapsnational.org) to avoid touching the existing
# Workspace MX/SPF on the root domain. EMAIL_FROM_ADDRESS must be on that verified
# domain; until verified, only onboarding@resend.dev can send. NOTE: after setting
# EMAIL_FROM_ADDRESS, run `npm run seed:pages` so the contact form's emailFrom
# picks up the new sender (it's baked into the form doc at seed time).
#RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
#EMAIL_FROM_ADDRESS=no-reply@mail.mapsnational.org
#EMAIL_FROM_NAME=MAPS National
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Spam protection (optional) — Google reCAPTCHA v3 on all form-builder forms.
#   Unset            -> no challenge; forms submit as-is. Zero infra.
#   Both keys set    -> the FormBlock mints an invisible v3 token on submit and
#                       a server hook verifies it with Google before the
#                       submission is stored or emailed. Low-score / missing
#                       tokens are rejected with 403.
#
# Setup: register a reCAPTCHA v3 site at https://www.google.com/recaptcha/admin
# (add localhost for dev + the prod domain). It gives a site key (public, safe
# to expose) and a secret key (server-only). RECAPTCHA_MIN_SCORE is the reject
# threshold, 0.0 (bot) to 1.0 (human); 0.5 is Google's suggested default.
#NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#RECAPTCHA_SECRET_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#RECAPTCHA_MIN_SCORE=0.5
# ---------------------------------------------------------------------------
