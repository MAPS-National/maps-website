{
  "name": "maps-website",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-docker.ps1",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:ci": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "import": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm src/import/cli.ts",
    "import:prose": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/import-prose.ts",
    "rehost:images": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/rehost-images.ts",
    "import:slider": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/import-slider.ts",
    "backup:prod": "node scripts/backup-prod.mjs",
    "refresh:staging": "node scripts/refresh-staging.mjs",
    "refresh:staging:check": "node scripts/refresh-lock.check.mjs",
    "refresh:local": "node scripts/refresh-local.mjs",
    "refresh:local:check": "node scripts/refresh-lock.check.mjs",
    "ensure:admin": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/ensure-admin.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reindex:search": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/reindex-search.ts",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "seed:header": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/seed-header.ts",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation node --import tsx/esm scripts/seed-pages.ts",
    "seed:about": "npm run seed:pages",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.86.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/email-resend": "^3.86.0",
    "@payloadcms/live-preview-react": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-form-builder": "3.86.0",
    "@payloadcms/plugin-nested-docs": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-search": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "^3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-navigation-menu": "^1.2.19",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.6.1",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.577.0",
    "next": "16.2.10",
    "next-sitemap": "^4.2.3",
    "payload": "3.86.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "sharp": "0.35.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "^1.0.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "^10.5.4",
    "csv-parse": "^7.0.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": "22.x",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
